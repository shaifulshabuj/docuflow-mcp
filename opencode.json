{
  "$schema": "https://opencode.ai/config.json",
  // NOTE: "type": "local" is OpenCode's term for stdio transport.
  // If OpenCode deprecates this field, replace with "transport": "stdio".
  "mcp": {
    "docuflow": {
      "command": "node",
      "args": ["packages/server/dist/index.js"],
      "type": "local"
    },
    "waymark": {
      "command": "node",
      "args": [
        ".waymark/server.js",
        "--project-root", ".",
        "--db-path", ".waymark/waymark.db"
      ],
      "type": "local"
    }
  }
}
