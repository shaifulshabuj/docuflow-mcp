# docuflow-mcp — Isolated Agent Development Environment
#
# Purpose: Run builds, tests, and installs in an isolated linux/arm64 container.
#          The agent can only touch the mounted /workspace (this repo).
#
# Build:  scripts/dev-container.sh  (handles build + run automatically)
# Manual: container build --tag docuflow-dev:latest --file Dockerfile.dev .

FROM ubuntu:24.04

LABEL org.opencontainers.image.title="docuflow-dev"
LABEL org.opencontainers.image.description="Isolated dev environment for docuflow-mcp — Node 22"

# ── Base toolchain ────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates git bash unzip wget sudo \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js 22 ────────────────────────────────────────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── GitHub CLI (gh) ───────────────────────────────────────────────────────────
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=arm64 signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] \
        https://cli.github.com/packages stable main" \
        | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# ── Claude Code CLI ───────────────────────────────────────────────────────────
# Auth is provided via mounted ~/.claude at container runtime (read-only).
RUN curl -fsSL https://claude.ai/install.sh | bash \
    || echo "⚠  Claude CLI install failed — mount credentials and retry at runtime"
ENV PATH="/root/.claude/local/bin:/root/.local/bin:$PATH"

# ── Git config ────────────────────────────────────────────────────────────────
RUN git config --global --add safe.directory /workspace

# ── npm global prefix (writable inside container) ────────────────────────────
RUN npm config set prefix /usr/local

WORKDIR /workspace

CMD ["/bin/bash", "--login"]
