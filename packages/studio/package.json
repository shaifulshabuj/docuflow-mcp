{
  "name": "@doquflow/studio",
  "version": "2.0.5",
  "description": "DocuFlow studio — advanced MCP tools, web UI, REST API, sync orchestration",
  "author": "Docuflow <hello@doquflows.dev>",
  "license": "MIT",
  "homepage": "https://github.com/doquflows/docuflow",
  "repository": {
    "type": "git",
    "url": "https://github.com/doquflows/docuflow.git"
  },
  "bugs": {
    "url": "https://github.com/doquflows/docuflow/issues"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "claude-code",
    "documentation",
    "codebase",
    "developer-tools"
  ],
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "require": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    },
    "./lib": {
      "require": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    },
    "./mcp": {
      "require": "./dist/mcp/index.js"
    },
    "./dist/tools/*": "./dist/tools/*.js"
  },
  "typesVersions": {
    "*": {
      "lib": [
        "./dist/lib.d.ts"
      ],
      "mcp": [
        "./dist/mcp/index.d.ts"
      ]
    }
  },
  "bin": {
    "docuflow-studio": "./dist/mcp/index.js"
  },
  "files": [
    "dist/**",
    "ui-dist/**",
    "README.md"
  ],
  "dependencies": {
    "@doquflow/core": "2.0.5",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/cors": "^2.8.17",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.10",
    "@types/d3-zoom": "^3.0.8",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.6"
  },
  "scripts": {
    "build": "tsc -p tsconfig.mcp.json && vite build",
    "build:mcp": "tsc -p tsconfig.mcp.json",
    "build:ui": "vite build",
    "dev:ui": "vite",
    "start:api": "node dist/api/index.js",
    "test": "vitest run --passWithNoTests"
  }
}
