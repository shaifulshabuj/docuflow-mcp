{
  "version": "2",
  "platforms": [
    "claude",
    "copilot-cli"
  ],
  "policies": {
    "allowedPaths": [
      ".",
      "./**",
      "src/**",
      "lib/**",
      "packages/**",
      ".github/**",
      "scripts/**",
      ".docuflow/**",
      ".devloop/**",
      ".claude/**",
      ".vscode/**",
      "docs/**",
      "release/**",
      "*.json",
      "*.md",
      "*.ts",
      "*.tsx",
      "*.js",
      "*.jsx",
      "*.css",
      "*.html",
      "*.yml",
      "*.yaml",
      "*.sh",
      "tests/**",
      "devloop.config.sh"
    ],
    "blockedPaths": [
      ".env",
      ".env.*",
      "/etc/**",
      "/usr/**",
      "node_modules/**",
      "secrets/**",
      "*.key",
      "*.pem",
      "**/*.key",
      "**/*.pem",
      ".waymark/**",
      ".git/objects/**",
      ".git/refs/remotes/**"
    ],
    "allowedCommands": [
      "npm",
      "node",
      "git",
      "tsc",
      "eslint",
      "vite",
      "typescript",
      "ts-node",
      "prettier",
      "jest",
      "mocha",
      "yarn",
      "pnpm",
      "cat",
      "grep",
      "find",
      "ls",
      "cd",
      "pwd",
      "mkdir",
      "touch",
      "cp",
      "mv",
      "rm",
      "curl",
      "wget",
      "which",
      "command"
    ],
    "blockedCommands": [
      "DROP TABLE",
      "DROP DATABASE",
      "chmod 777",
      "regex:\\|\\s*bash",
      "regex:\\|\\s*sh\\b",
      "sudo",
      "passwd",
      "chown",
      "chgrp",
      "mkfs",
      "dd if=",
      "deluser",
      "delgroup"
    ],
    "requireApproval": [
      "waymark.config.json"
    ],
    "maxBashOutputBytes": 50000
  }
}
